<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>servicos</title>
</head>
<body>
    <h1>Servicos</h1>
    <hr>
    <h3>confira nossos serviços!</h3>
<!--exibindo o array de objetos em uma tabela com forEach-->
     <table border="1">
     <tr>
        <th>servico</th>
        <th>descricao</th>
         <th>preco</th>

         <% servicos.forEach(function(servico){ %>
           <tr>
          <td><%= servico.servico %></td>
         <td><%=  servico.descricao %></td>
         <td><%= servico.preco %></td>
           </tr>
            <% }) %>

     </table>



    <p><a href="/">voltar para a pagina inicial</a></p>
</body>
</html>