<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>clientes</title>
</head>
<body>
    <h1>clientes</h1>
    <hr>
    <h3>confira nossos clientes</h3>

    <!--exibindo uma variavel Javascript dentro do HTML-->
    <!--comentario no EJS <%# %>-->

    <!--percorrendo o vetor atraves do forEach-->
      <% listaCliente.forEach(function(cliente){ %>
         <p>
          <a href="/clientes/<%=cliente %>">

          <%= cliente %>

          </a>
        </p>
     <%}) %>
     
     <p><a href="/">voltar para a pagina inicial</a></p>
</body>
</html>