<%- include ('partials/header.ejs') %>
<%- include ('partials/navbar.ejs') %>
    <h1>Servicos</h1>
    <hr>
    <h3>confira nossos serviços!</h3>
<!--exibindo o array de objetos em uma tabela com forEach-->
     <table class="table table-bordered table-houver">
      <tr class="table-dark">
        <th>servico</th>
        <th>descricao</th>
         <th>preco</th>
      </tr>
         <% servicos.forEach(function(servico){ %>
           <tr>
          <td><%= servico.servico %></td>
         <td><%=  servico.descricao %></td>
         <td><%= servico.preco %></td>
           </tr>
            <% }) %>

     </table>



    <p><a href="/">voltar para a pagina inicial</a></p>

    <%- include ('partials/footer.ejs') %>