<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>produtos</title>
</head>
<body>
    <h1>produtos</h1>
    <hr>
    <h3>confira nossos produtos</h3>

    <!--exibindo uma variavel Javascript dentro do HTML-->
    <!--comentario no EJS <%# %>-->

    <!--percorrendo o vetor atraves do forEach-->
      <% listaProdutos.forEach(function(produto){ %>
         <p>
          <a href="/produtos/<%= produto %>">

          <%= produto %>

          </a>
        </p>
     <%}) %>
     

     <p><a href="/">voltar para a pagina inicial</a></p>
</body>
</html>